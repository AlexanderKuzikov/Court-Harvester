{
  "name": "court-harvester",
  "version": "0.2.0",
  "description": "CLI-утилита для сбора справочника судов РФ через API DaData",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx",
    "start": "tsx src/index.ts",
    "harvest:59": "tsx src/index.ts harvest --region 59",
    "harvest:full": "tsx src/examples/test-full-harvester.ts",
    "harvest:full:phase4": "tsx src/examples/test-full-phase4.ts",
    "harvest:full:phase5": "tsx src/examples/test-full-phase5.ts",
    "harvest:full:phase6": "tsx src/examples/test-full-phase6.ts",
    "harvest:full:phase7": "tsx src/examples/test-full-phase7.ts",
    "find-gaps": "tsx src/examples/find-gaps.ts",
    "test-missing": "tsx src/examples/test-missing-codes.ts",
    "count-prefixes": "tsx src/examples/count-prefixes.ts",
    "check-min-values": "tsx src/examples/check-min-values.ts",
    "example:test-client": "tsx src/examples/test-client.ts",
    "example:test-harvester": "tsx src/examples/test-harvester.ts",
    "example:test-pagination": "tsx src/examples/test-pagination.ts",
    "test": "vitest",
    "format": "prettier --write \"src/**/*.ts\"",
    "check-ai": "tsx src/examples/check-ai-courts.ts",
    "sort-export": "tsx src/examples/sort-and-export.ts",
    "check-region-00": "tsx src/examples/check-region-00.ts",
    "test-vs": "tsx src/examples/test-vs-search.ts",
    "harvest:full:phase8": "tsx src/examples/test-full-phase8.ts",
    "analyze-regions": "tsx src/examples/analyze-regions.ts",
    "harvest:full:phase9b": "tsx src/examples/test-full-phase9b.ts",
    "analyze-prefixes": "tsx src/examples/analyze-prefixes.ts",
    "update": "tsx src/examples/update.ts search",
    "update:full": "tsx src/examples/update.ts full"
  },
  "keywords": ["dadata", "courts", "russia", "harvester", "cli"],
  "author": "AlexanderKuzikov",
  "license": "Apache-2.0",
  "dependencies": {
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "bottleneck": "^2.19.5",
    "commander": "^15.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "prettier": "^3.9.5",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
